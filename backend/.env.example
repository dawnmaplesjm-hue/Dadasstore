# Backend Configuration
# Copy this file and name it .env
# Fill in your actual values

# Server
PORT=5000

# Database (we'll add this later)
# DATABASE_URL=postgresql://user:password@localhost:5432/dadasstore

# Stripe Payment
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# FRONTEND_URL=http://localhost:5174
# STRIPE_CURRENCY=usd

# Security
# JWT_SECRET=your_super_secret_key_here

# Admin
ADMIN_EMAIL=admin@dadasstore.com
ADMIN_PASSWORD=Love1877
ADMIN_TOKEN=dadasstore-dev-token

# Google Merchant Center (optional, used by merchant:feed and merchant:sync)
# Public base URL of your storefront (used to build product links and image URLs)
# MERCHANT_BASE_URL=https://your-domain.com
# MERCHANT_PRODUCT_LINK_TEMPLATE=https://your-domain.com/?product={id}
# MERCHANT_IMAGE_LINK_TEMPLATE=https://your-domain.com{imagePath}
# MERCHANT_OUTPUT_FILE=./merchant-feed.tsv
# MERCHANT_BRAND=Dada's Store
# MERCHANT_CURRENCY=USD
# MERCHANT_CONTENT_LANGUAGE=en
# MERCHANT_TARGET_COUNTRY=US
# MERCHANT_GOOGLE_PRODUCT_CATEGORY=Media > Books
# MERCHANT_PRODUCT_TYPE=Digital Products > Ebooks
#
# For Content API sync:
# MERCHANT_CENTER_ID=123456789
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# OR use inline JSON for CI environments:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
